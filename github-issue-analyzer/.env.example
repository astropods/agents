# =============================================================================
# GitHub Issue Analyzer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For local dev:     ast dev
# For deployment:    ast deploy
# =============================================================================

# OpenAI API key — powers the agent (GPT-4o) and ingestion analysis
OPENAI_API_KEY=

# GitHub personal access token — used by the ingestion pipeline to fetch issues
# Needs at least `public_repo` scope (or `repo` for private repositories)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=
